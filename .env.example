# Kopieer dit bestand naar .env en vul in.

# Wachtwoord voor het admin-paneel (/admin). VERPLICHT in productie.
ADMIN_PASSWORD=kies-een-lang-wachtwoord

# Geheime sleutel voor sessies. Genereer met: openssl rand -hex 32
AUTH_SECRET=

# Resend API key voor e-mails (https://resend.com — gratis tot 100 mails/dag).
# Zonder key werkt de site gewoon, maar worden er geen mails verstuurd.
RESEND_API_KEY=

# Afzenderadres voor mails (moet een geverifieerd domein zijn in Resend)
MAIL_FROM="RitsIT <noreply@ritsit.be>"

# Jouw eigen mailbox: hier komen contactaanvragen binnen
MAIL_TO=kiano.rits@gmail.com

# Publieke URL van de site (voor links in mails en SEO)
SITE_URL=http://localhost:3000

# Map waar de database en uploads bewaard worden (standaard: ./data)
# DATA_DIR=/var/www/site-data
